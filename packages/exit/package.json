{
  "name": "@rootstock-kits/exit",
  "version": "0.1.0",
  "description": "Pay-to-Bitcoin widget: BIP-21 parsing, Flyover/PowPeg routing, swap-to-RBTC, and exit progress UI for Rootstock dApps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@rsksmart/bridges-core-sdk": "^0.5.0",
    "@rsksmart/flyover-sdk": "^1.8.0",
    "@rsksmart/powpeg-sdk": "^1.1.0",
    "@rsksmart/rsk-swap-sdk": "^1.3.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.67.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "keywords": [
    "rootstock",
    "rsk",
    "bitcoin",
    "flyover",
    "powpeg",
    "peg-out",
    "bip21"
  ]
}
